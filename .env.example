# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Email Settings (для отправки писем)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mail.ru
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@mail.ru
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@mail.ru

# Alternative: Console backend for development
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Default passwords for management commands
MANAGER_PASSWORD=change-me-in-production
TEST_USER_PASSWORD=change-me-in-production